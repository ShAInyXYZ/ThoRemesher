# Python
__pycache__/
*.py[cod]
*.egg-info/
*.egg
.eggs/
build/
dist/
.venv/
venv/
env/

# Temporary session data (uploaded/processed models)
_tmp/
ThoRemesher/_tmp/

# Vendored third-party engines (download/build separately — not our code):
#   _quadwild     = QuadWild-BiMDF prebuilt binary (GPL3) github.com/cgg-bern/quadwild-bimdf
#   _neurcross    = NeurCross repo (AGPL3) github.com/QiujieDong/NeurCross
#   _autoremesher = AutoRemesher source + pybind11 build (MIT) github.com/huxingyi/autoremesher
#   _libqex / _openmesh* = local C++ builds for the libQEx path (unused at runtime)
_quadwild/
_neurcross/
_autoremesher/
_libqex/
_openmesh*/

# Built pybind11 extension (from _autoremesher/ — produced by build.sh)
autoremesher_ext*.so

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Test models / exports (keep repo clean)
*.glb
*.gltf
*.fbx
*.obj
*.ply
*.stl
!ThoRemesher/static/**/*.glb
